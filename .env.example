# ========== API Server Configuration ==========
# API_HOST=0.0.0.0
# API_PORT=8000  # MMAudio uses 8000, HunyuanVideo-Foley uses 8001
# LOG_LEVEL=info

# ========== Cache Configuration ==========
# VIDEO_CACHE_MAX_GB=32  # Maximum size of video cache in GB
# VIDEO_CACHE_TTL_MIN=60  # Time-to-live for cached videos in minutes
# VIDEO_FRAME_CHECK=false  # Enable frame count checking (performance impact)

# ========== Device Configuration ==========
# FORCE_DEVICE=auto  # Force specific device: cuda, mps, cpu, or auto
# FORCE_DTYPE=bfloat16  # Force specific dtype: float32, bfloat16, float16, or auto

# ========== Model Paths ==========
# MMAUDIO_PATH=/workspace/model-tests/repos/MMAudio
# HYVF_PATH=/workspace/model-tests/repos/HunyuanVideo-Foley
# HYVF_WEIGHTS_PATH=/workspace/model-tests/models/HunyuanVideo-Foley

# ========== Performance ==========
# ALLOW_TF32=true  # Allow TF32 acceleration for matmul and cudnn
# ENABLE_TRACEMALLOC=true  # Enable memory profiling

# ========== Logging ==========
# LOG_BUFFER_SIZE=500  # Keep last N log entries in memory
