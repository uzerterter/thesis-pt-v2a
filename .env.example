# ========== API Server Configuration ==========
# API_HOST=0.0.0.0
# API_PORT=8000  # MMAudio uses 8000, HunyuanVideo-Foley uses 8001
# LOG_LEVEL=info

# ========== Cache Configuration ==========
# VIDEO_CACHE_MAX_GB=32  # Maximum size of video cache in GB
# VIDEO_CACHE_TTL_MIN=60  # Time-to-live for cached videos in minutes
# VIDEO_FRAME_CHECK=false  # Enable frame count checking (performance impact)

# ========== Device Configuration ==========
# FORCE_DEVICE=auto  # Force specific device: cuda, mps, cpu, or auto
# FORCE_DTYPE=bfloat16  # Force specific dtype: float32, bfloat16, float16, or auto

# ========== Model Paths ==========
# MMAUDIO_PATH=/workspace/model-tests/repos/MMAudio
# HYVF_PATH=/workspace/model-tests/repos/HunyuanVideo-Foley
# HYVF_WEIGHTS_PATH=/workspace/model-tests/models/HunyuanVideo-Foley

# ========== Performance ==========
# ALLOW_TF32=true  # Allow TF32 acceleration for matmul and cudnn
# ENABLE_TRACEMALLOC=true  # Enable memory profiling

# ========== Logging ==========
# LOG_BUFFER_SIZE=500  # Keep last N log entries in memory

# ========== Full Stack — REQUIRED settings ==========
# Run 'bash setup.sh' to be guided through these interactively.

# [REQUIRED] Cloudflare tunnel token — needed for cloudflared to start.
# How to get: Cloudflare Zero Trust → Networks → Tunnels
#             → your tunnel → Configure → Token (copy button)
# No cert.pem or JSON credentials file needed when using a token.
# TUNNEL_TOKEN=eyJ...your-token-here...

# [REQUIRED] URL to the BBC Sound Archive database dump (metadata + embeddings).
# See db-dump/README.md. Google Drive sharing links work directly.
# DB_DUMP_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view

# ========== Full Stack — Optional settings ==========

# Path to BBC .wav files on the host.
# Default: ../BBCSoundDownloader/sounds (relative to this repo's parent dir)
# Set this if your sounds are stored elsewhere.
# BBC_SOUNDS_DIR=/absolute/path/to/your/bbc/sounds

# ========== Database (Sound Search + Tools) ==========
# BBC_DB_PASSWORD=change_me
# DATABASE_URL=postgresql://ludwig:change_me@postgres:5432/bbc_sounds
